{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MediaTagger",
  "version": "1.0.0",
  "identifier": "com.mediatagger",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MediaTagger",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "copyright": "Copyright © 2026 acliunianc",
    "category": "Utility",
    "shortDescription": "Local media tagging with content-hash labels",
    "longDescription": "Tag and organize local images, videos, and audio files. Labels follow file content via blake3 hashing.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
